{
  "compilerOptions": {
    "jsx": "react",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "noUncheckedSideEffectImports": false,
    // TODO(ts7): moduleResolution "node" is deprecated in TS 6 and removed in TS 7.
    // Migrate to "node16" or "bundler" (requires "module" change + fixing Bit-linked
    // package resolution for components like @teambit/harmony.modules.load-trace).
    "ignoreDeprecations": "6.0",
    "types": ["node", "mocha", "chai", "jest"],
    "target": "es2015",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": [
    "scopes",
    "e2e",
    "components"
  ],
  "exclude": [
    "node_modules",
    "e2e/fixtures",
    "scopes/semantics/schema/mock"
  ]
}
