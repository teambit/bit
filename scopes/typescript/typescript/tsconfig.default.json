{
  // TODO(ts7): "moduleResolution: node" is deprecated in TS 6 and removed in TS 7.
  // Migrate to "node16" (with "module: node16") or "bundler" (with "module: esnext"/"preserve")
  // before adopting TS 7. The ignoreDeprecations flag below is a temporary bridge only.
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "jsx": "react",
    "composite": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noImplicitAny": false,
    "removeComments": true,
    "preserveConstEnums": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "dist"
  ]
}
